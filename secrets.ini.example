; Copier vers secrets.ini et remplir les valeurs.
;   cp secrets.ini.example secrets.ini
; Ne jamais committer secrets.ini (il est dans .gitignore).
; Le build exige que secrets.ini existe (ou définir DEVICE_KEY_B64, FACTORY_TOKEN, MQTT_USER, MQTT_PASS en env).

[env]
custom_device_key_b64 =
custom_factory_token  =
custom_mqtt_user      =
custom_mqtt_pass      =
